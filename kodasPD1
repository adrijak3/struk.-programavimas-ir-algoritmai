#include <iostream>
#include <iomanip>
using namespace std;

int main()
{
    double GBP_Bendras = 0.8729;
    double GBP_Pirkti = 0.8600;
    double GBP_Parduoti = 0.9220;
    double USD_Bendras = 1.1793;
    double USD_Pirkti = 1.1460;
    double USD_Parduoti = 1.2340;
    double INR_Bendras = 104.6918;
    double INR_Pirkti = 101.3862;
    double INR_Parduoti = 107.8546;

    int pasirinkimas;
    string valiuta;
    double kiekis;

    cout << fixed << setprecision(2);

    while (true)  // program repeats forever
    {
        cout << "\nPasirinkite veiksma:\n";
        cout << "1 - palyginimas\n";
        cout << "2 - pirkimas\n";
        cout << "3 - pardavimas\n";
        cout << "0 - baigti programa\n";

        cin >> pasirinkimas;

        if (pasirinkimas == 0)
            break;

        cout << "valiuta - GBP, USD, INR: ";
        cin >> valiuta;

        switch (pasirinkimas)
        {
        case 1: // palyginimas
            if (valiuta == "GBP")
            {
                cout << "1 EUR yra " << GBP_Bendras << " GBP\n";
                cout << "1 GBP yra " << 1 / GBP_Bendras << " EUR\n";
            }
            else if (valiuta == "USD")
            {
                cout << "1 EUR yra " << USD_Bendras << " USD\n";
                cout << "1 USD yra " << 1 / USD_Bendras << " EUR\n";
            }
            else if (valiuta == "INR")
            {
                cout << "1 EUR yra " << INR_Bendras << " INR\n";
                cout << "1 INR yra " << 1 / INR_Bendras << " EUR\n";
            }
            else
            {
                cout << "Neteisinga valiuta\n";
            }
            break;

        case 2: // pirkimas
            cout << "Euru kiekis - ";
            cin >> kiekis;

            if (valiuta == "GBP")
                cout << "Tai yra lygu " << kiekis * GBP_Pirkti << " GBP\n";
            else if (valiuta == "USD")
                cout << "Tai yra lygu " << kiekis * USD_Pirkti << " USD\n";
            else if (valiuta == "INR")
                cout << "Tai yra lygu " << kiekis * INR_Pirkti << " INR\n";
            else
                cout << "Neteisinga valiuta\n";

            break;

        case 3: // pardavimas
            cout << "Kiekis valiutos - ";
            cin >> kiekis;

            if (valiuta == "GBP")
                cout << "Tai yra lygu " << kiekis / GBP_Parduoti << " EUR\n";
            else if (valiuta == "USD")
                cout << "Tai yra lygu " << kiekis / USD_Parduoti << " EUR\n";
            else if (valiuta == "INR")
                cout << "Tai yra lygu " << kiekis / INR_Parduoti << " EUR\n";
            else
                cout << "Neteisinga valiuta\n";

            break;

        default:
            cout << "Netinkamas pasirinkimas\n";
        }
    }

    cout << "Programa baigta.\n";
    return 0;
}
